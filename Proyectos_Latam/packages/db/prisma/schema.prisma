// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// CORE & AUTH (SHARED)
// -----------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // LatamaX
  posts         Post[]
  likes         Like[]
  followers     Follow[]  @relation("following")
  following     Follow[]  @relation("follower")

  // PayLat
  balance       Float     @default(0)
  transactions  Transaction[]

  // PinLat
  pins          Pin[]
  boards        Board[]

  // KickLatam
  streams       Stream[]
  chats         ChatMessage[]
}

// -----------------------------------------------------------------------------
// LATAMAX (Social Network)
// -----------------------------------------------------------------------------

model Post {
  id        String   @id @default(cuid())
  content   String
  image     String?
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  likes     Like[]
  createdAt DateTime @default(now())
}

model Like {
  id      String @id @default(cuid())
  user    User   @relation(fields: [userId], references: [id])
  userId  String
  post    Post   @relation(fields: [postId], references: [id])
  postId  String

  @@unique([userId, postId])
}

model Follow {
  follower    User   @relation("follower", fields: [followerId], references: [id])
  followerId  String
  following   User   @relation("following", fields: [followingId], references: [id])
  followingId String

  @@id([followerId, followingId])
}

// -----------------------------------------------------------------------------
// PAYLAT (Neobank)
// -----------------------------------------------------------------------------

model Transaction {
  id          String   @id @default(cuid())
  amount      Float
  type        String   // "DEPOSIT", "TRANSFER", "PAYMENT"
  description String?
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  createdAt   DateTime @default(now())
}

// -----------------------------------------------------------------------------
// PINLAT (Pinterest)
// -----------------------------------------------------------------------------

model Pin {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  author      User     @relation(fields: [authorId], references: [id])
  authorId    String
  board       Board?   @relation(fields: [boardId], references: [id])
  boardId     String?
  createdAt   DateTime @default(now())
}

model Board {
  id        String   @id @default(cuid())
  name      String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  pins      Pin[]
  createdAt DateTime @default(now())
}

// -----------------------------------------------------------------------------
// KICKLATAM (Streaming)
// -----------------------------------------------------------------------------

model Stream {
  id        String   @id @default(cuid())
  title     String
  isLive    Boolean  @default(false)
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  createdAt DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  content   String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
}

// -----------------------------------------------------------------------------
// VIALATIN & TRADUCELA (Geodata / Translations)
// -----------------------------------------------------------------------------

model GeoReport {
  id        String   @id @default(cuid())
  type      String   // "TRAFFIC", "ACCIDENT", "POLICE"
  lat       Float
  lng       Float
  userId    String
  createdAt DateTime @default(now())
}
